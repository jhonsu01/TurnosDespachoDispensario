{
  "name": "turnos-dispensario-asistente",
  "productName": "Dispensario Asistente",
  "version": "0.7.0",
  "description": "Módulo de atención para asistentes del dispensario: solo turnos y despacho, conectado por red al servidor principal",
  "main": "src/main.js",
  "author": "Jhon Supelano",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win msi --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dispensario.asistente",
    "productName": "Dispensario Asistente",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": [
        "msi"
      ],
      "icon": "build/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "runAfterFinish": true,
      "artifactName": "TurnosDispensario-Asistente-${version}.msi"
    }
  }
}
